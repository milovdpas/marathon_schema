# Optional — enables Google Drive cloud sync (server-side OAuth).
# Leave these unset and the app works fine using localStorage only.
#
# Create an OAuth Client ID of type "Web application" in Google Cloud Console,
# add the redirect URI(s) below to it, and publish the consent screen to
# production (Testing mode expires refresh tokens after 7 days).
# See the "Cloud sync setup" section in README.md for step-by-step instructions.

# From the OAuth client (Web application). The secret is confidential — never
# prefix it with NEXT_PUBLIC_ and never commit it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must EXACTLY match an Authorized redirect URI on the OAuth client.
# Dev default; in production set it to https://<your-domain>/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Secret used to encrypt the session cookie. Must be at least 32 characters.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=
